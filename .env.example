NODE_ENV=production
PORT=5000

# --- Database (Railway Postgres) ---
# Railway provides DATABASE_URL automatically when you add a Postgres plugin and
# reference it from this service. Prefer the INTERNAL URL (postgres.railway.internal)
# for service-to-service traffic — it stays on Railway's private network and needs no SSL.
# The public proxy URL (*.proxy.rlwy.net) is for external clients and requires SSL.
DATABASE_URL=${{Postgres.DATABASE_URL}}
# SSL override: leave unset for auto-detection. disable=no SSL, require=SSL (self-signed allowed).
# DB_SSL=
# Pool size — keep at/below the Postgres plan's connection limit divided by replica count.
# DB_POOL_MAX=10

# --- Auth ---
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_EXPIRES_IN=7d

# --- CORS ---
# Comma-separated list of allowed origins in production (admin/web app URLs).
ALLOWED_ORIGINS=https://your-admin.vercel.app

# --- Payments: provider selection ---
# Default engine for new payments: mpesa | mulaflow
PAYMENT_PROVIDER=mpesa

# --- MulaFlow (official payment engine; fill once credentials are available) ---
MULAFLOW_BASE_URL=https://api.mulaflow.com
MULAFLOW_API_KEY=
MULAFLOW_WEBHOOK_SECRET=
MULAFLOW_CALLBACK_URL=https://your-api.up.railway.app/api/payments/webhook/mulaflow

# --- M-Pesa / Safaricom Daraja (fallback engine) ---
# sandbox: tests against https://sandbox.safaricom.co.ke with the values below as-is.
# production: set to "production" AFTER Daraja go-live, then swap KEY/SECRET/SHORTCODE/PASSKEY
# for your LIVE credentials (sandbox creds 401 against the live API).
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
# Sandbox test shortcode 174379 + public sandbox passkey work out of the box.
# In production these become your own paybill/till number and Lipa Na M-Pesa passkey.
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
# Must be a public HTTPS URL Safaricom can reach — use the Railway PUBLIC domain, NOT *.railway.internal.
# Both /api/payments/mpesa/callback (this) and /api/payments/webhook/mpesa are accepted by the routes.
MPESA_CALLBACK_URL=https://your-api.up.railway.app/api/payments/mpesa/callback
# Source IPs Safaricom sends callbacks from; any other source is rejected with 403 in production.
# Full published whitelist below (sandbox + production share it). Confirm against your Daraja portal before go-live.
MPESA_SAFARICOM_IPS=196.201.214.200,196.201.214.206,196.201.213.114,196.201.214.207,196.201.214.208,196.201.213.44,196.201.212.127,196.201.212.138,196.201.212.129,196.201.212.136,196.201.212.74,196.201.212.69
MPESA_B2C_RESULT_URL=https://your-api.up.railway.app/api/payments/mpesa/b2c-result
MPESA_B2C_TIMEOUT_URL=https://your-api.up.railway.app/api/payments/mpesa/b2c-timeout
MPESA_INITIATOR_NAME=
MPESA_SECURITY_CREDENTIAL=
